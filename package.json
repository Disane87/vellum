{
  "name": "vellum",
  "version": "1.0.0",
  "private": true,
  "description": "A desktop email client for IMAP/SMTP",
  "author": {
    "name": "Marco Franke",
    "email": "disane@icloud.com"
  },
  "main": "electron/dist/main.js",
  "workspaces": [
    "packages/shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "build:shared": "npm run build -w packages/shared",
    "build:backend": "npm run build -w backend",
    "build:frontend": "npm run build -w frontend",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend && npm run build:electron",
    "dev": "concurrently -n be,fe -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:electron": "concurrently -n be,fe,el-watch,el -c blue,green,cyan,yellow \"npm run dev:backend\" \"npm run dev:frontend\" \"tsc -p electron/tsconfig.json -w\" \"wait-on tcp:4200 && electronmon .\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "test:backend": "npm test -w backend",
    "test:frontend": "npm test -w frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.vellum.app",
    "productName": "Vellum",
    "directories": {
      "output": "release"
    },
    "icon": "electron/icon.png",
    "files": [
      "electron/dist/**/*",
      "electron/icon.png"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "imapflow/**",
          "nodemailer/**",
          "better-sqlite3/**",
          "sanitize-html/**",
          "mailparser/**",
          "generic-pool/**",
          "@nestjs/**",
          "reflect-metadata/**",
          "rxjs/**",
          "class-transformer/**",
          "class-validator/**",
          "uuid/**",
          "iterare/**",
          "tslib/**"
        ]
      },
      {
        "from": "frontend/dist/vellum/browser",
        "to": "frontend/browser"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    },
    "publish": null,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "concurrently": "^9.2.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "electronmon": "^2.0.4",
    "semantic-release": "^24.0.0",
    "wait-on": "^9.0.4"
  }
}
